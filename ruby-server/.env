# .env サンプル

# Barix Instreamer 側の接続情報
BARIX_IP=36.3.129.234
PORT=80
BARIX_USERNAME=your_username
BARIX_PASSWORD=your_password

# 一時保存ディレクトリ
TEMP_DIR=./temp

# 1ファイルあたりの録音秒数
DURATION_SEC=30

# 再接続までの待機秒数
RETRY_WAIT=10

# 無音mp3ファイルのパス
SILENCE_MP3=./silence.mp3

# キャッシュ保存期間（分）
CACHE_KEEP_MINUTES=60

# Barix 側の送信仕様（例: プロトコル、エンコーディング等）
# 例: PROTOCOL=HTTP, ENCODING=mp3, BITRATE=128k
PROTOCOL=HTTP
ENCODING=mp3
BITRATE=128k
